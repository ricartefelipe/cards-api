# Copie primeiro:   cp .env.example .env
# Preencha os campos em branco (ex.: openssl rand -hex 24). Nunca comite .env.

# ---------- MariaDB (Compose) ----------
MARIADB_USER=cards
MARIADB_ROOT_PASSWORD=
MARIADB_PASSWORD=

# ---------- Aplicação Quarkus ----------
DB_USERNAME=cards
DB_PASSWORD=
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=quarkus
# Igual ao "secret" do client backend-service no ficheiro quarkus-realm.json importado pelo Keycloak
KEYCLOAK_CLIENT_SECRET=

CARRIER_WEBHOOK_API_KEY=
PROCESSOR_WEBHOOK_API_KEY=

CVV_DEFAULT_TTL_SECONDS=900

# ---------- Keycloak (bootstrap admin do container) ----------
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=
